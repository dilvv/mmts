MMTS_package_path:
  HGCal_Module_Production_Toolkit: external_packages/HGCal_Module_Production_Toolkit
  hgcal_module_testing_gui: external_packages/hgcal-module-testing-gui
MMTS_hardwares:
  keithley:
    DiscoveryMode: by-id
    Resource: 'ASRL/dev/serial/by-id/usb-FTDI_USB_Serial_Converter_FT9GC67T-if00-port0::INSTR' ## or 'ASRL/dev/ttyUSB1::INSTR'
    Terminal: Rear ## available options: "Front" or "Rear"
    WiresPolarization: Forward ## available options: "Forward" or "Reverse"
    BaudRate: 9600 ## this should be matched with keithley
  vitek:
    DiscoveryMode: by-id
    Resource: 'ASRL/dev/serial/by-id/usb-Prolific_Technology_Inc._USB-Serial_Controller_CEBGb11BS12-if00-port0::INSTR' ## or 'ASRL/dev/ttyUSB0::INSTR'
externalURL:
  EnvMonitor:
    URL: "http://hep11.phys.ntu.edu.tw:3000/d/thermalboxenvironmentformmts/thermal-box-environment-for-mmts?orgId=1&theme=light&from=now-1h&to=now&timezone=browser&kiosk" ### your grafana dashboard here
    height: 350px
  IVCurveOnline:
    URL: 'http://hep11.phys.ntu.edu.tw:3000/d/ivcurveformmts/iv-curve-plot-for-mmts?orgId=1&theme=light&from=now-24h&to=now&timezone=browser&var-N_MODULE_SHOW=24&var-bp_material=$__all&var-resolution=$__all&var-roc_version=$__all&var-geometry=$__all&var-sen_thickness=$__all&var-iv_grade=$__all&kiosk'
    height: 650px
inspector: NTU Lab ### this option would be filled to database "inspector"

thermalcycle_iterations:
  ### key would be put into hgcapi - mmts_iv_test - iteration
  ### value as a description would be shown on MMTS GUI option.
  iteration_1: 'iteration_1: room condition, high humidity'
  iteration_2: 'iteration_2: first low temperature'
  iteration_3: 'iteration_3: last low temperature'
  iteration_4: 'iteration_4: final IV, normal temperature'
  test: 'testing here'
