### the same as Andrew's module testing GUI
DBDatabase: hgcdb
DBHostname: 'hgcdb IP address like 192.168.0.1'
DBPassword: 'hgcdb password'
DBUsername: postgres
DataLoc:  /some/path/
DebugMode: true
DefaultFontSize: '15'
DefaultMaxVoltage: 500
FPGAHostname:
- cmshgcaltb4.lan.local.cmu.edu
- cmshgcalkria1.lan.local.cmu.edu
FPGAType:
- Trenz
- Kria
HVDiscoveryMode: by-id
HVResource: ASRL/dev/ttyUSB0::INSTR
HVTerminal: Rear
HVWiresPolarization: Reverse
HasHVSwitch: true
HasLocalDB: true
HasRHSensor: false
HexactrlSWBranch: ROCv3
Inspectors:
- acrobert
- simurthy
- jestein
- ppalit
- akallilt
MACSerial: CM
PCKeyLoc: /home/hgcal/.ssh/id_rsa
Station: Single-Module Test Stand
TestingPCOpSys: Alma9

