 cd /home/mmts/MultiModuleTeststandUI && ls -l external_packages/HGCal_Module_Production_Toolkit/configuration.yaml && [ -e external_packages/HGCal_Module_Production_Toolkit/configuration.yaml ] && echo EXISTS || echo MISSING
 cd /home/mmts/MultiModuleTeststandUI && ls -l external_packages/HGCal_Module_Production_Toolkit/configuration.yaml && file external_packages/HGCal_Module_Production_Toolkit/configuration.yaml
 cd /home/mmts/MultiModuleTeststandUI && rm -f external_packages/HGCal_Module_Production_Toolkit/configuration.yaml && . .venv/bin/activate && make -f makefile_initialize_this_GUI task3b_create_mmts_configuration
 set -e
cd /home/mmts/MultiModuleTeststandUI
rm -f external_packages/HGCal_Module_Production_Toolkit/configuration.yaml
ln -s "$PWD/data/mmts_configurations.yaml" external_packages/HGCal_Module_Production_Toolkit/configuration.yaml
